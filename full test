# =============================================================================
# SECTION 3: MODEL FITTING
# =============================================================================
# We use grades 1, 3, and 5 as our three time points (g=0,1,2 in paper notation)
# g0 = 1st grade, g1 = 3rd grade, g2 = 5th grade
#
# Covariate vector (xi): ses, female, black, hispanic, asian, frl
# Teacher effect: random intercept per teacher per grade (phi_ig * theta_g)
# School effect:  random intercept per school per grade (lambda_ig * eta_g)
# =============================================================================

covariates <- "ses + female + black + hispanic + asian + low_inc + mom_ed"

```




Model 1: Covariate Adjustment Model

$$y_{ig} = \mu_g + \beta_gx_i + \gamma^*y_{i,g-1} +\theta_j+ \eta_k + \epsilon_ig$$


Where: 
$y_{ig}$ - Student i's score in grade g
$\mu_g$ - overall mean for grade g
$\beta_gx_i$ - effect of student covariates (all demographics...)
$\gamma^*y_{i,g-1}$ - effect of prior score 
$\eta_k$ - random effect of school k 
$\epsilon_ig$ - leftover residual error
 
Assumes residuals are independent across grades. 
prior score serves as a covariate

$\theta_j$ - random effect of teacher j



In the general model, the score at grade g
g includes contributions from
all prior teachers, scaled by alpha:

α parameters control how much of a prior teacher's effect
persists into the current score. So:

```{r}
cat("\n=== MODEL 1: COVARIATE ADJUSTMENT ===\n")

# Spring-K -> 1st grade
formula_cov_g1 <- as.formula(paste(
  "score_g1 ~ score_sk +", covariates, "+ (1 | teacher_g1) + (1 | school_g1)"
))
model_cov_g1 <- lmer(formula_cov_g1, data = analytic, REML = FALSE)
summary(model_cov_g1)

# 1st grade -> 3rd grade
formula_cov_g3 <- as.formula(paste(
  "score_g3 ~ score_g1 +", covariates, "+ (1 | teacher_g3) + (1 | school_g3)"
))
model_cov_g3 <- lmer(formula_cov_g3, data = analytic, REML = FALSE)
summary(model_cov_g3)

# Extract teacher BLUPs
blup_cov_g1 <- ranef(model_cov_g1)$teacher_g1 %>%
  rownames_to_column("teacher") %>%
  rename(blup_cov_g1 = `(Intercept)`)

blup_cov_g3 <- ranef(model_cov_g3)$teacher_g3 %>%
  rownames_to_column("teacher") %>%
  rename(blup_cov_g3 = `(Intercept)`)

vc_cov_g1 <- as.data.frame(VarCorr(model_cov_g1))
vc_cov_g3 <- as.data.frame(VarCorr(model_cov_g3))
cat("Covariate Adj. teacher variance (G1):", vc_cov_g1$vcov[vc_cov_g1$grp == "teacher_g1"], "\n")
cat("Covariate Adj. teacher variance (G3):", vc_cov_g3$vcov[vc_cov_g3$grp == "teacher_g3"], "\n")

```


OUTPUTS:

Teacher effect accounts for about 2.1% of total variation in G1 comparison. The school has a much higher effect of 7.0% of variance. 


Key limitation to this model 1: 

Covariate adjustment assumes that residuals across years are independent - students unexplained G1 residual tells you nothing about their G3 residual. Students are individuals and can carry unobserved traits with them that arent captured by the prior score. 





Model 2: Gain Score Model 

Instead of controlling for prior achievement, we are looking at the difference in achievement. 

Makes an assumption that all alpha parameters equal 1, meaning teacher effects from prior years persist completely and forever into future scores. Implicitly saying that the kindergarden teacher effect is carried forward fully into 1st grade. 

$$d_{ig} = \mu_g + \beta_gx_i  +\phi^\prime_{ig}\theta_g+ \lambda^\prime_{ig}\eta_g + \epsilon_{ig}$$


Where: 
$y_{ig}$ - gain score (current - prior)
$\mu_g$ - mean gain for grade g
$\beta_gx_i$ - effect of student covariates (all demographics...)
$\eta_k$ - random effect of school k 
$\epsilon_{ig}$ - leftover residual error
 
Assumes residuals are independent across grades. 
prior score serves as a covariate

$\phi^\prime_{ig}\theta_g$ - random effect of teacher for grade g


When you take the difference yig−yi,g−1y_{ig} - y_{i,g-1}
yig​−yi,g−1​ to get the gain score, the prior teacher terms only cancel out cleanly if α=1.

If α<1, there's a leftover piece of the prior teacher's effect still sitting in the gain score that the model doesn't account for — which becomes an omitted variable and can bias your teacher effect estimates.

Residuals assumed independent across grades. 

```{r}

cat("\n=== MODEL 2: GAIN SCORE MODEL ===\n")

# K -> G1 gain
formula_gain_g1 <- as.formula(paste(
  "gain_sk_to_g1 ~", covariates, "+ (1 | teacher_g1) + (1 | school_g1)"
))
model_gain_g1 <- lmer(formula_gain_g1, data = gains, REML = FALSE)
summary(model_gain_g1)

# G1 -> G3 gain
formula_gain_g3 <- as.formula(paste(
  "gain_g1_to_g3 ~", covariates, "+ (1 | teacher_g3) + (1 | school_g3)"
))
model_gain_g3 <- lmer(formula_gain_g3, data = gains, REML = FALSE)
summary(model_gain_g3)

# Extract BLUPs
blup_gain_g1 <- ranef(model_gain_g1)$teacher_g1 %>%
  rownames_to_column("teacher") %>%
  rename(blup_gain_g1 = `(Intercept)`)

blup_gain_g3 <- ranef(model_gain_g3)$teacher_g3 %>%
  rownames_to_column("teacher") %>%
  rename(blup_gain_g3 = `(Intercept)`)

vc_gain_g1 <- as.data.frame(VarCorr(model_gain_g1))
vc_gain_g3 <- as.data.frame(VarCorr(model_gain_g3))
cat("Gain Score teacher variance (G1):", vc_gain_g1$vcov[vc_gain_g1$grp == "teacher_g1"], "\n")
cat("Gain Score teacher variance (G3):", vc_gain_g3$vcov[vc_gain_g3$grp == "teacher_g3"], "\n")


```


They produce nearly identical teacher variance estimates and BLUP rankings because they're making similarly restrictive assumptions — just in different directions. Model 1 assumes an auto regressive residual structure; Model 2 assumes α=1. Both ignore the correlation in residuals *across years* for the same student. 





Model 3: Cross-Classified (CC) Model

$$y_{ig} = \mu_g + \gamma_gi + \mu_i + \gamma_ig  + \sum_{y=0}^g \phi^\prime_{it}\theta_t+ \lambda^\prime_{ig}\eta_g+\epsilon_{ig}$$

Where: 
$y_{ig}$ - student i's score in grade g
$\mu_g + \gamma_gi$ - overall linear growth trend
$\mu_i$ - random student intercept
$\gamma_ig$ - random student growth slope
$\sum_{y=0}^g \phi^\prime_{it}\theta_t$ - all prior teacher contribute, (alpha = 1 so no loss of contribution)


$\lambda^\prime_{ig} \eta_g$ - school random effect

$\epsilon_{ig}$ - residual 



All years modeled simultaneously rather than breaking it up into differences between years.
Prior teachers are fully included, effects fully presist. But explicitly represented rather than expressed as a prior score. 


CC model uses a linear growth trajectory, assuming scores grow at a constant rate across grades. 




 


```{r}



cat("\n=== MODEL 3: CROSS-CLASSIFIED (CC) MODEL ===\n")

cc_data <- long %>%
  left_join(analytic %>% select(student_id, teacher_sk, teacher_g1, teacher_g3,
                                school_sk, school_g1, school_g3),
            by = "student_id") %>%
  mutate(
    # time: 0=spring-K, 1=1st grade, 2=3rd grade
    time = grade
  )

# CC model: random student intercept + slope, crossed teacher REs per grade
# Teacher effects from prior grades persist forward (alpha=1 assumption)
formula_cc <- score ~
  time +                                              # linear time trend
  ses + female + black + hispanic + asian + low_inc + mom_ed +
  (1 | student_id) +                          # random student growth
  (1 | teacher_sk) +                                 # K teacher (persists all years)
  (1 | teacher_g1) +                                 # G1 teacher (persists from G1)
  (1 | teacher_g3) +                                 # G3 teacher effect
  (1 | school_sk)                                    # school random effect

model_cc <- lmer(formula_cc, data = cc_data, REML = FALSE,
                 control = lmerControl(optimizer = "bobyqa",
                                       optCtrl = list(maxfun = 2e5)))
summary(model_cc)

blup_cc_sk <- ranef(model_cc)$teacher_sk %>%
  rownames_to_column("teacher") %>% rename(blup_cc_sk = `(Intercept)`)
blup_cc_g1 <- ranef(model_cc)$teacher_g1 %>%
  rownames_to_column("teacher") %>% rename(blup_cc_g1 = `(Intercept)`)
blup_cc_g3 <- ranef(model_cc)$teacher_g3 %>%
  rownames_to_column("teacher") %>% rename(blup_cc_g3 = `(Intercept)`)

vc_cc <- as.data.frame(VarCorr(model_cc))
cat("CC model teacher variance (K):", vc_cc$vcov[vc_cc$grp == "teacher_sk"], "\n")
cat("CC model teacher variance (G1):", vc_cc$vcov[vc_cc$grp == "teacher_g1"], "\n")
cat("CC model teacher variance (G3):", vc_cc$vcov[vc_cc$grp == "teacher_g3"], "\n")

```


Key outputs of model 3:

The CC model attributes slightly less variance to teachers, as the random student intercept is doing work by absorbing stable difference in the individual that are uncontrolled in model 1 or 2 as was just done by prior score. 


The largest piece of variance is the student, which tells that who the student is matters more than any other factor in the model. 

Half of all variance in scores is stable student-level differences. Teachers collectively account for about 4.6% — still meaningful, but a very different picture than Models 1 and 2 suggested.


G3 teachers show the most variance. This partly reflects that by 3rd grade there's simply more spread in scores to explain, but it also reflects the cross-classified structure — G3 teacher effects are estimated net of whatever K and G1 teachers already contributed, which is a more precise attribution than Models 1 and 2 could achieve.









# Model 4: TVAAS Layered Model 


$$y_{ig} = \mu_g + \beta_gx_i +\sum_{t=0}^g\phi^\prime_{it}\theta_t + \lambda^\prime_{ig}\eta_g+\mu_i+\epsilon_{ig}$$

Where:

$y_{ig}$ - Student i's score in grade g 
$\mu_g$ - free mean per grade, no linearity constraint 
$\beta_gx_i$ - student covariates, demographics ...
$\sum_{t=0}^g\phi^\prime_{it}\theta_t$ - all prior teacher effects, (alpha = 1)
$\lambda^\prime_{ig}\eta_g$ - school random effect
$\mu_i$ - student random intercept
$\epsilon_{ig}$ - residual 


Layered model differences, no longer a linear growth for overall mean grade between grades. Now it allows each grade to have its own estimated mean from the data. Slightly more flexible. 


No random student slope, meaning students can differ in intercept but are assumed to grow at the same rate. 

an unrestricted covariance structure for the residuals









```{r}

cat("\n=== MODEL 4: TVAAS LAYERED MODEL ===\n")

layered_data <- cc_data %>%
  mutate(grade_f = factor(grade, labels = c("K", "G1", "G3")))

formula_layered <- score ~
  grade_f +                                           # free mean per grade
  ses + female + black + hispanic + asian + low_inc + mom_ed +
  (1 | teacher_sk) +                                  # K teacher (alpha=1, persists)
  (1 | teacher_g1) +                                  # G1 teacher (persists from G1)
  (1 | teacher_g3) +                                  # G3 teacher effect
  (1 | student_id) +                                  # student random intercept
  (1 | school_sk)                                     # school effect

model_layered <- lmer(formula_layered, data = layered_data, REML = FALSE,
                      control = lmerControl(optimizer = "bobyqa",
                                            optCtrl = list(maxfun = 2e5)))
summary(model_layered)

blup_lay_sk <- ranef(model_layered)$teacher_sk %>%
  rownames_to_column("teacher") %>% rename(blup_lay_sk = `(Intercept)`)
blup_lay_g1 <- ranef(model_layered)$teacher_g1 %>%
  rownames_to_column("teacher") %>% rename(blup_lay_g1 = `(Intercept)`)
blup_lay_g3 <- ranef(model_layered)$teacher_g3 %>%
  rownames_to_column("teacher") %>% rename(blup_lay_g3 = `(Intercept)`)

vc_lay <- as.data.frame(VarCorr(model_layered))
cat("Layered teacher variance (K):", vc_lay$vcov[vc_lay$grp == "teacher_sk"], "\n")
cat("Layered teacher variance (G1):", vc_lay$vcov[vc_lay$grp == "teacher_g1"], "\n")
cat("Layered teacher variance (G3):", vc_lay$vcov[vc_lay$grp == "teacher_g3"], "\n")

```

AIC comparison:

CC:      151,075.9
Layered: 149,627.4


The big picture so far is that Models 3 and 4 tell essentially the same story about teachers once you account for persistent student differences, but the Layered model does it with better fit and fewer restrictive assumptions about growth trajectories.

The Layered model fits meaningfully better — a difference of about 1,448 AIC points on the same data. That's strong evidence that freeing up the grade means matters. The linearity assumption in CC was doing real damage to model fit.



# Model 5: The General Model

$$y_{ig} = \mu_g + \beta_g' x_i + \sum_{t=0}^{g-1} \alpha_{gt}\phi_{it}'\theta_t + \phi_{ig}'\theta_g + \lambda_{ig}'\eta_g + \varepsilon_{ig}$$

Big difference between this and other models are estimated alpha parameters, so that teacher effect is not fully kept. 

ParameterMeaningα10\alpha_{10}
α10​how much of the K teacher effect persists into G1α20\alpha_{20}
α20​how much of the K teacher effect persists into G3α21\alpha_{21}
α21​how much of the G1 teacher effect persists into G3


In a larger dataset, this would be a full covariance structure. 

The big thing to look at is the alpha estimates to see how close it is to 1 or 0, which would indicate different overarching effects of teachers. 

```{r}

# -----------------------------------------------------------------------------
# MODEL 5: GENERAL MODEL (alpha estimated correctly)
# -----------------------------------------------------------------------------
# Strategy: fit the layered model first (already done), then estimate alpha
# by regressing each grade's residuals on the prior grade's teacher effects.
#
# alpha_gt = Cov(residual_g, teacher_effect_t) / Var(teacher_effect_t)
#
# More practically: for each student, compute the fitted teacher contribution
# from prior grades using the layered BLUPs, then estimate how much of that
# contribution actually shows up in the current grade's score after removing
# all other fixed effects.
# -----------------------------------------------------------------------------

cat("\n=== MODEL 5: GENERAL MODEL (alpha estimated) ===\n")

# Step 1: Get grade-specific means from layered model fixed effects
mu_sk <- fixef(model_layered)["(Intercept)"]
mu_g1 <- fixef(model_layered)["(Intercept)"] + fixef(model_layered)["grade_fG1"]
mu_g3 <- fixef(model_layered)["(Intercept)"] + fixef(model_layered)["grade_fG3"]

# Step 2: Compute covariate-adjusted scores (remove fixed effects from scores)
# This isolates the part of each score not explained by covariates or grade means
cov_vars <- c("ses", "female", "black", "hispanic", "asian", "low_inc", "mom_ed")

get_resid <- function(outcome, data) {
  f <- as.formula(paste(outcome, "~", paste(cov_vars, collapse = " + ")))
  m <- lm(f, data = data, na.action = na.exclude)
  residuals(m)
}

general_data2 <- analytic %>%
  mutate(
    resid_sk = get_resid("score_sk", analytic),
    resid_g1 = get_resid("score_g1", analytic),
    resid_g3 = get_resid("score_g3", analytic)
  ) %>%
  # Attach layered BLUPs for each teacher
  left_join(blup_lay_sk %>% rename(teacher_sk = teacher), by = "teacher_sk") %>%
  left_join(blup_lay_g1 %>% rename(teacher_g1 = teacher), by = "teacher_g1") %>%
  rename(
    theta_sk = blup_lay_sk,
    theta_g1 = blup_lay_g1
  ) %>%
  mutate(across(c(theta_sk, theta_g1), ~ replace_na(., 0)))

# Step 3: Estimate alpha_10 — how much K teacher effect persists into G1
# resid_g1 = alpha_10 * theta_sk + teacher_g1_RE + eps
formula_alpha10 <- resid_g1 ~ theta_sk + (1 | teacher_g1)
model_alpha10 <- lmer(formula_alpha10, data = general_data2, REML = FALSE)
alpha_10_est <- fixef(model_alpha10)["theta_sk"]
cat("Estimated alpha_10 (K teacher -> G1):", round(alpha_10_est, 3), "\n")

# Step 4: Estimate alpha_20 and alpha_21 — persistence into G3
# resid_g3 = alpha_20 * theta_sk + alpha_21 * theta_g1 + teacher_g3_RE + eps
formula_alpha_g3 <- resid_g3 ~ theta_sk + theta_g1 + (1 | teacher_g3)
model_alpha_g3 <- lmer(formula_alpha_g3, data = general_data2, REML = FALSE)
alpha_20_est <- fixef(model_alpha_g3)["theta_sk"]
alpha_21_est <- fixef(model_alpha_g3)["theta_g1"]
cat("Estimated alpha_20 (K teacher -> G3):", round(alpha_20_est, 3), "\n")
cat("Estimated alpha_21 (G1 teacher -> G3):", round(alpha_21_est, 3), "\n")

# Step 5: Extract G1 and G3 teacher BLUPs from general model
blup_gen_g1 <- ranef(model_alpha10)$teacher_g1 %>%
  rownames_to_column("teacher") %>% rename(blup_gen_g1 = `(Intercept)`)
blup_gen_g3 <- ranef(model_alpha_g3)$teacher_g3 %>%
  rownames_to_column("teacher") %>% rename(blup_gen_g3 = `(Intercept)`)

vc_gen_g1 <- as.data.frame(VarCorr(model_alpha10))
vc_gen_g3 <- as.data.frame(VarCorr(model_alpha_g3))
cat("General Model teacher variance (G1):", vc_gen_g1$vcov[vc_gen_g1$grp == "teacher_g1"], "\n")
cat("General Model teacher variance (G3):", vc_gen_g3$vcov[vc_gen_g3$grp == "teacher_g3"], "\n")

# Alpha summary table
alpha_summary <- tibble(
  Parameter   = c("alpha_10", "alpha_20", "alpha_21"),
  Description = c("K teacher -> G1", "K teacher -> G3", "G1 teacher -> G3"),
  Estimate    = c(alpha_10_est, alpha_20_est, alpha_21_est),
  Layered_assumption = 1.0
)
cat("\n--- Alpha persistence estimates ---\n")
print(alpha_summary)
