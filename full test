# =============================================================================
# SECTION 5: POSTERIOR PROBABILITY PLOTS (replicates paper Figure 2)
# =============================================================================
# For each teacher, compute approximate posterior probability that
# their true effect > 0, using the BLUP and its standard error.
# P(theta_j > 0 | data) ~ pnorm(BLUP_j / SE_j)
# =============================================================================

compute_post_prob <- function(model, grp_name) {
  blups  <- ranef(model, condVar = TRUE)[[grp_name]]
  se     <- sqrt(attr(blups, "postVar")[1, 1, ])
  blup_v <- blups[, 1]
  prob   <- pnorm(blup_v / se)
  tibble(teacher = rownames(blups), blup = blup_v, se = se, post_prob = prob)
}

