```{r}

# -----------------------------------------------------------------------------
# MODEL 5: GENERAL MODEL — Full Joint Maximum Likelihood Estimation
# Based directly on McCaffrey et al. (2004) Equations 1-5
#
# Parameters estimated jointly:
#   - mu_g: grade-specific means (3 values)
#   - beta_g: covariate effects (assumed constant across grades for parsimony)
#   - alpha_10, alpha_20, alpha_21: teacher persistence parameters
#   - sigma2_theta_g: teacher variance per grade (3 values)
#   - sigma2_eta: school variance
#   - sigma2_mu: student random intercept variance
#   - Sigma_eps: 3x3 unstructured residual covariance matrix (6 values)
#
# Strategy:
#   For each student, the marginal variance-covariance of their 3 scores
#   is a function of all the above parameters. We maximize the joint
#   marginal likelihood over all students.
# -----------------------------------------------------------------------------


cat("\n=== MODEL 5: GENERAL MODEL (Full Joint MLE) ===\n")

library(Matrix)

# --- 5a. Prepare data --------------------------------------------------------

# Covariate matrix (same for all grades, time-invariant)
cov_vars <- c("ses", "female", "black", "hispanic", "asian", "low_inc", "mom_ed")

# Complete cases only for joint model
gen_full <- analytic %>%
  select(student_id,
         score_sk, score_g1, score_g3,
         teacher_sk, teacher_g1, teacher_g3,
         school_sk,
         all_of(cov_vars)) %>%
  drop_na()

cat("N for General Model:", nrow(gen_full), "\n")

# Outcome matrix: N x 3
Y <- as.matrix(gen_full %>% select(score_sk, score_g1, score_g3))

# Covariate matrix: N x p
X <- as.matrix(gen_full %>% select(all_of(cov_vars)))
X <- cbind(1, X)  # add intercept
p <- ncol(X)

N <- nrow(gen_full)

# Teacher assignment matrices (phi): N x J_g indicator matrices
# phi_ig = 1 if student i had teacher j in grade g, 0 otherwise
make_phi <- function(teacher_vec) {
  teachers <- sort(unique(teacher_vec))
  J <- length(teachers)
  phi <- matrix(0, nrow = length(teacher_vec), ncol = J)
  for (j in seq_along(teachers)) {
    phi[teacher_vec == teachers[j], j] <- 1
  }
  phi
}

phi_sk <- make_phi(gen_full$teacher_sk)
phi_g1 <- make_phi(gen_full$teacher_g1)
phi_g3 <- make_phi(gen_full$teacher_g3)

# School assignment matrix (lambda): N x K indicator
phi_sch <- make_phi(gen_full$school_sk)

J_sk <- ncol(phi_sk)
J_g1 <- ncol(phi_g1)
J_g3 <- ncol(phi_g3)
K_sch <- ncol(phi_sch)

cat("K teachers:", J_sk, J_g1, J_g3, "\n")
cat("Schools:", K_sch, "\n")


# --- 5b. Marginal variance-covariance for one student -----------------------
#
# For student i, scores (y_sk, y_g1, y_g3) have marginal covariance:
#
# Var(y_i) = Phi_i * D_theta * Phi_i' + Lambda_i * D_eta * Lambda_i'
#            + sigma2_mu * 1_3 * 1_3' + Sigma_eps
#
# Where:
#   Phi_i is the 3x(J_sk+J_g1+J_g3) block matrix of teacher assignments
#         with alpha scaling for prior grades
#   D_theta = block-diag(sigma2_sk*I, sigma2_g1*I, sigma2_g3*I)
#   sigma2_mu * 1*1' = student random intercept contribution
#   Sigma_eps = 3x3 unstructured residual covariance
#
# The alpha parameters enter through Phi_i:
#   Grade SK row: [phi_sk_i,          0,       0      ]
#   Grade G1 row: [alpha_10*phi_sk_i,  phi_g1_i, 0    ]
#   Grade G3 row: [alpha_20*phi_sk_i,  alpha_21*phi_g1_i, phi_g3_i]

build_Vi <- function(i, params) {
  # Unpack parameters
  sigma2_sk  <- exp(params["log_s2_tsk"])
  sigma2_g1  <- exp(params["log_s2_tg1"])
  sigma2_g3  <- exp(params["log_s2_tg3"])
  sigma2_sch <- exp(params["log_s2_sch"])
  sigma2_mu  <- exp(params["log_s2_mu"])
  alpha_10   <- params["alpha_10"]
  alpha_20   <- params["alpha_20"]
  alpha_21   <- params["alpha_21"]

  # Residual covariance (unstructured, use Cholesky parameterization)
  # Lower triangle: l11, l21, l22, l31, l32, l33
  l11 <- exp(params["log_l11"])
  l21 <- params["l21"]
  l22 <- exp(params["log_l22"])
  l31 <- params["l31"]
  l32 <- params["l32"]
  l33 <- exp(params["log_l33"])
  L <- matrix(c(l11, 0,   0,
                l21, l22, 0,
                l31, l32, l33), nrow = 3, byrow = TRUE)
  Sigma_eps <- L %*% t(L)

  # Teacher contribution to covariance
  # phi vectors for student i
  p_sk <- phi_sk[i, ]   # length J_sk
  p_g1 <- phi_g1[i, ]   # length J_g1
  p_g3 <- phi_g3[i, ]   # length J_g3
  p_sch <- phi_sch[i, ]  # length K_sch

  # Contribution of K teachers (sigma2_sk)
  # Appears in all 3 grade equations scaled by alpha
  c_sk_sk <- sigma2_sk * sum(p_sk^2)
  c_sk_g1 <- sigma2_sk * alpha_10 * sum(p_sk^2)
  c_sk_g3 <- sigma2_sk * alpha_20 * sum(p_sk^2)

  # Contribution of G1 teachers (sigma2_g1)
  c_g1_g1 <- sigma2_g1 * sum(p_g1^2)
  c_g1_g3 <- sigma2_g1 * alpha_21 * sum(p_g1^2)

  # Contribution of G3 teachers (sigma2_g3)
  c_g3_g3 <- sigma2_g3 * sum(p_g3^2)

  # School contribution
  c_sch <- sigma2_sch * sum(p_sch^2)

  # Build 3x3 teacher+school covariance matrix
  V_teach <- matrix(0, 3, 3)

  # K teacher block
  V_teach[1,1] <- c_sk_sk
  V_teach[1,2] <- V_teach[2,1] <- c_sk_g1
  V_teach[1,3] <- V_teach[3,1] <- c_sk_g3
  V_teach[2,2] <- c_sk_g1 * alpha_10 + c_g1_g1
  V_teach[2,3] <- V_teach[3,2] <- c_sk_g3 * alpha_10 + c_g1_g3
  V_teach[3,3] <- c_sk_g3 * alpha_20 + c_g1_g3 * alpha_21 + c_g3_g3

  # School block (same structure, no alpha)
  V_sch <- c_sch * matrix(1, 3, 3)

  # Student random intercept
  V_mu <- sigma2_mu * matrix(1, 3, 3)

  # Total marginal covariance
  V_teach + V_sch + V_mu + Sigma_eps
}


# --- 5c. Log-likelihood function --------------------------------------------

neg_log_lik <- function(params) {

  # Fixed effects: separate intercept per grade + shared covariate effects
  mu_sk   <- params["mu_sk"]
  mu_g1   <- params["mu_g1"]
  mu_g3   <- params["mu_g3"]
  beta    <- params[paste0("beta", 1:(p-1))]  # covariate effects (no intercept)

  # Grade-specific mean vectors (N x 1 each)
  Xbeta   <- X[, 2:p, drop = FALSE] %*% beta  # N x 1, covariate part only

  mu_vec_sk <- mu_sk + Xbeta
  mu_vec_g1 <- mu_g1 + Xbeta
  mu_vec_g3 <- mu_g3 + Xbeta

  ll <- 0

  for (i in 1:N) {
    # Residual vector for student i
    r_i <- c(
      Y[i, 1] - mu_vec_sk[i],
      Y[i, 2] - mu_vec_g1[i],
      Y[i, 3] - mu_vec_g3[i]
    )

    # Marginal covariance
    Vi <- tryCatch(
      build_Vi(i, params),
      error = function(e) return(NULL)
    )
    if (is.null(Vi)) return(1e10)

    # Check positive definite
    eigs <- eigen(Vi, symmetric = TRUE, only.values = TRUE)$values
    if (any(eigs <= 0)) return(1e10)

    # Multivariate normal log-likelihood contribution
    ll_i <- -0.5 * (log(det(Vi)) + t(r_i) %*% solve(Vi) %*% r_i + 3 * log(2 * pi))
    ll <- ll + ll_i
  }

  return(-ll)  # return negative for minimization
}


# --- 5d. Starting values from layered model ---------------------------------
# Warm-start the optimizer using layered model estimates

vc_lay_full <- as.data.frame(VarCorr(model_layered))

s2_tsk_start <- vc_lay_full$vcov[vc_lay_full$grp == "teacher_sk"]
s2_tg1_start <- vc_lay_full$vcov[vc_lay_full$grp == "teacher_g1"]
s2_tg3_start <- vc_lay_full$vcov[vc_lay_full$grp == "teacher_g3"]
s2_sch_start <- vc_lay_full$vcov[vc_lay_full$grp == "school_sk"]
s2_mu_start  <- vc_lay_full$vcov[vc_lay_full$grp == "student_id"]
s2_eps_start <- vc_lay_full$vcov[vc_lay_full$grp == "Residual"]

fe_lay <- fixef(model_layered)
beta_start <- fe_lay[cov_vars]

# Residual Cholesky starting values (diagonal, equal variance)
l_start <- sqrt(s2_eps_start / 3)

params_start <- c(
  mu_sk       = as.numeric(fe_lay["(Intercept)"]),
  mu_g1       = as.numeric(fe_lay["(Intercept)"] + fe_lay["grade_fG1"]),
  mu_g3       = as.numeric(fe_lay["(Intercept)"] + fe_lay["grade_fG3"]),
  setNames(as.numeric(beta_start), paste0("beta", 1:(p-1))),
  alpha_10    = 1.0,   # start at layered model assumption
  alpha_20    = 1.0,
  alpha_21    = 1.0,
  log_s2_tsk  = log(s2_tsk_start),
  log_s2_tg1  = log(s2_tg1_start),
  log_s2_tg3  = log(s2_tg3_start),
  log_s2_sch  = log(s2_sch_start),
  log_s2_mu   = log(s2_mu_start),
  log_l11     = log(l_start),
  l21         = 0,
  log_l22     = log(l_start),
  l31         = 0,
  l32         = 0,
  log_l33     = log(l_start)
)

cat("Number of parameters:", length(params_start), "\n")
cat("Optimizing... this may take several minutes.\n")


# --- 5e. Optimize ------------------------------------------------------------
# Use optim with L-BFGS-B for gradient-based optimization
# Note: this is a large optimization problem. Be patient.

opt_result <- optim(
  par     = params_start,
  fn      = neg_log_lik,
  method  = "L-BFGS-B",
  control = list(
    maxit   = 500,
    trace   = 1,      # print progress
    REPORT  = 10
  )
)

cat("\nOptimization converged:", opt_result$convergence == 0, "\n")
cat("Convergence code:", opt_result$convergence, "\n")


# --- 5f. Extract and report results -----------------------------------------

est <- opt_result$par

cat("\n--- General Model Results ---\n")

cat("\nGrade means:\n")
cat("  Spring-K:", round(est["mu_sk"], 3), "\n")
cat("  Grade 1: ", round(est["mu_g1"], 3), "\n")
cat("  Grade 3: ", round(est["mu_g3"], 3), "\n")

cat("\nAlpha persistence parameters:\n")
cat("  alpha_10 (K -> G1): ", round(est["alpha_10"], 3), "\n")
cat("  alpha_20 (K -> G3): ", round(est["alpha_20"], 3), "\n")
cat("  alpha_21 (G1 -> G3):", round(est["alpha_21"], 3), "\n")

cat("\nTeacher variance components:\n")
cat("  K teachers (sigma2_sk): ", round(exp(est["log_s2_tsk"]), 3), "\n")
cat("  G1 teachers (sigma2_g1):", round(exp(est["log_s2_tg1"]), 3), "\n")
cat("  G3 teachers (sigma2_g3):", round(exp(est["log_s2_tg3"]), 3), "\n")

cat("\nSchool variance:", round(exp(est["log_s2_sch"]), 3), "\n")
cat("Student variance:", round(exp(est["log_s2_mu"]),  3), "\n")

# Recover residual covariance matrix
l11 <- exp(est["log_l11"])
l21 <- est["l21"]
l22 <- exp(est["log_l22"])
l31 <- est["l31"]
l32 <- est["l32"]
l33 <- exp(est["log_l33"])
L_est <- matrix(c(l11, 0,   0,
                  l21, l22, 0,
                  l31, l32, l33), nrow = 3, byrow = TRUE)
Sigma_eps_est <- L_est %*% t(L_est)
rownames(Sigma_eps_est) <- colnames(Sigma_eps_est) <- c("K", "G1", "G3")

cat("\nResidual covariance matrix (Sigma_eps):\n")
