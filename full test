# ECLS-K restricted-use data come as SAS transport files or fixed-width .dat
# Public-use data are available as SPSS or SAS files from NCES.
#
# Key variables we need (ECLS-K variable names shown):
#   CHILDID    - unique child identifier
#   S*TCHID    - teacher ID per round (e.g., S2TCHID = grade 1 teacher)
#   S*SCHID    - school ID per round
#   C*R4MSCL   - math IRT scale score per round (or reading: C*R4RSCL)
#   WKSESL     - SES composite (continuous)
#   GENDER     - child gender (1=male, 2=female)
#   RACE       - race/ethnicity (categorical)
#   P*FREELUN  - free/reduced lunch eligibility (binary)
#   WKMOMED    - mother's education level






# --- 1b. Select & rename key variables --------------------------------------
# ECLS-K has many hundreds of variables. We pull just what we need.
# Wave labels:  K=kindergarten, G1=1st grade, G3=3rd, G5=5th, G8=8th
# Round codes in variable names: 1=fall-K, 2=spring-K, 3=fall-1st,
#   4=spring-1st, 5=spring-3rd, 6=spring-5th, 7=spring-8th


```{r}


eclsk <- raw %>%
  select(
    student_id  = CHILDID,

    # Math IRT scale scores
    score_fk    = C1R4MSCL,   # Fall Kindergarten  (round 1)
    score_sk    = C2R4MSCL,   # Spring Kindergarten (round 2)
    score_g1    = C4R4MSCL,   # Spring 1st grade   (round 4)
    score_g3    = C5R4MSCL,   # Spring 3rd grade   (round 5)
    score_g5    = C6R4MSCL,   # Spring 5th grade   (round 6)
    score_g8    = C7R4MSCL,   # Spring 8th grade   (round 7)

    # Teacher IDs (T{round}_ID)
    teacher_fk  = T1_ID,      # Fall-K teacher
    teacher_sk  = T2_ID,      # Spring-K teacher
    teacher_g1  = T4_ID,      # 1st grade teacher
    teacher_g3  = T5_ID,      # 3rd grade teacher
    # Note: T6_ID / T7_ID not present in this file — no linked teacher for G5/G8

    # School IDs (S{round}_ID)
    school_fk   = S1_ID,
    school_sk   = S2_ID,
    school_g1   = S4_ID,
    school_g3   = S5_ID,
    school_g5   = S6_ID,

    # Student-level covariates
    ses         = WKSESL,     # SES composite (continuous, ~standardized)
    gender      = GENDER,     # 1=male, 2=female
    raceth      = WKRACETH,   # race/ethnicity composite
    mom_ed      = WKMOMED,    # mother's education (ordinal)
    poverty     = WKPOV_R     # poverty ratio (continuous)
  ) %>%
  mutate(
    # Binary demographic indicators
    female    = if_else(gender  == 2, 1L, 0L),
    black     = if_else(raceth  == 3, 1L, 0L),  # WKRACETH: 3=Black non-Hispanic
    hispanic  = if_else(raceth  == 5, 1L, 0L),  # 5=Hispanic
    asian     = if_else(raceth  == 2, 1L, 0L),  # 2=Asian non-Hispanic
    # Poverty flag: below poverty line = WKPOV_R <= 1.0
    low_inc   = if_else(poverty <= 1, 1L, 0L),
    # Make IDs character to prevent accidental numeric math on IDs
    across(c(student_id,
             teacher_fk, teacher_sk, teacher_g1, teacher_g3,
             school_fk, school_sk, school_g1, school_g3, school_g5),
           as.character)
  )

```




```{r}
# --- 1c. Recode missing values ----------------------------------------------
# ECLS-K uses negative codes for missing (-1, -7, -8, -9)
eclsk <- eclsk %>%
  mutate(across(where(is.numeric), ~ if_else(. < 0, NA_real_, .)))

```




```{r}
# --- 1d. Create analytic sample ---------------------------------------------
# For the core VAM models we focus on students with 3 linked years of data
# (1st, 3rd, 5th grade) to match the paper's 4-grade structure.
