analytic <- eclsk %>%
  filter(
    !is.na(score_sk),     # spring-K baseline score
    !is.na(score_g1),     # 1st grade score
    !is.na(score_g3),     # 3rd grade score
    !is.na(teacher_sk),   # spring-K teacher
    !is.na(teacher_g1),   # 1st grade teacher
    !is.na(teacher_g3)    # 3rd grade teacher
  )

cat("Analytic sample N:", nrow(analytic), "\n")
cat("Unique K teachers:", n_distinct(analytic$teacher_sk), "\n")
cat("Unique G1 teachers:", n_distinct(analytic$teacher_g1), "\n")
cat("Unique G3 teachers:", n_distinct(analytic$teacher_g3), "\n")
```


# --- 1e. Reshape to long format (needed for CC and Layered models) ----------
# Three time points: spring-K (g=0), 1st grade (g=1), 3rd grade (g=2)

```{r}
long <- analytic %>%
  select(student_id, ses, female, black, hispanic, asian, low_inc, mom_ed,
         score_sk, score_g1, score_g3,
         teacher_sk, teacher_g1, teacher_g3,
         school_sk, school_g1, school_g3) %>%
  pivot_longer(
    cols      = c(score_sk, score_g1, score_g3),
    names_to  = "grade_label",
    values_to = "score"
  ) %>%
  mutate(
    grade = case_when(
      grade_label == "score_sk" ~ 0,   # spring-K  = time 0
      grade_label == "score_g1" ~ 1,   # 1st grade = time 1
      grade_label == "score_g3" ~ 2    # 3rd grade = time 2
    ),
    teacher = case_when(
      grade == 0 ~ teacher_sk,
      grade == 1 ~ teacher_g1,
      grade == 2 ~ teacher_g3
    ),
    school = case_when(
      grade == 0 ~ school_sk,
      grade == 1 ~ school_g1,
      grade == 2 ~ school_g3
    )
  ) %>%
  select(-grade_label, -starts_with("teacher_"), -starts_with("school_"))
```




