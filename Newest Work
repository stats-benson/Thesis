# Step 2: Helper functions
clean_for_split <- function(df) {
  df |> select(-any_of(c("teacher_idx", "student_idx", "time_idx",
                          "P", "teacher_idx.x", "teacher_idx.y",
                          "student_idx.x", "student_idx.y",
                          "time_idx.x", "time_idx.y")))
}

reindex_teachers <- function(df) {
  idx <- df |> distinct(teacher_id) |> arrange(teacher_id) |>
    mutate(teacher_idx = row_number())
  df |> left_join(idx, by = "teacher_id")
}

reindex_all <- function(df) {
  s_idx <- df |> distinct(CHILDID) |> arrange(CHILDID) |>
    mutate(student_idx = row_number())
  t_idx <- df |> distinct(wave) |> arrange(wave) |>
    mutate(time_idx = row_number())
  df |> left_join(s_idx, by = "CHILDID") |> left_join(t_idx, by = "wave")
}

make_X <- function(df) {
  X <- df |> select(female, black, hispanic, asian,
                    other_race, disabled, poverty, ses_std) |> as.matrix()
  col_means <- colMeans(X, na.rm = TRUE)
  for (k in seq_len(ncol(X))) X[is.na(X[,k]), k] <- col_means[k]
  X
}

make_composite_data <- function(df) {
  X <- make_X(df)

  # Compute P fresh (P already dropped in clean_for_split)
  peer <- df |> group_by(school_id, wave) |>
    summarise(P = mean(y_prev_std, na.rm = TRUE), .groups = "drop")
  df <- df |> left_join(peer, by = c("school_id", "wave"))
  p_vals <- df[["P"]]
  p_vals[is.na(p_vals)] <- mean(p_vals, na.rm = TRUE)
  df[["P"]] <- p_vals

  S <- df |> distinct(teacher_idx, .keep_all = TRUE) |>
    arrange(teacher_idx) |>
    select(S_enrls, S_minor, S_sctyp, S_urban) |> as.matrix()
  S_means <- colMeans(S, na.rm = TRUE)
  for (k in seq_len(ncol(S))) S[is.na(S[,k]), k] <- S_means[k]

  list(N=nrow(df), I=max(df$student_idx), J=max(df$teacher_idx),
       K=ncol(X), L=ncol(S), TT=max(df$time_idx),
       y=df$y_std, y_prev=df$y_prev_std, P=df[["P"]], X=X, S=S,
       student_id=df$student_idx, teacher_id=df$teacher_idx,
       time_id=df$time_idx)
}

make_tvaas_data <- function(keep_ids) {
  keep  <- raw$CHILDID %in% keep_ids
  wide  <- raw[keep, ] |> select(CHILDID, all_of(score_cols))
  wide  <- wide |> mutate(across(all_of(score_cols), ~ (. - sc_mean) / sc_sd))
  Y     <- wide |> select(all_of(score_cols)) |> as.matrix()
  obs   <- (!is.na(Y)) * 1L
  Y[is.na(Y)] <- 0
  n_obs <- rowSums(obs)
  keep2 <- n_obs > 0
  Y <- Y[keep2,]; obs <- obs[keep2,]; n_obs <- n_obs[keep2]
  t_ids <- c()
  for (g in seq_len(G)) {
    tc <- teacher_cols[g]
    if (!is.na(tc) && tc %in% names(raw))
      t_ids <- c(t_ids, raw[[tc]][keep][keep2])
  }
  t_ids <- na.omit(unique(t_ids))
  t_idx <- tibble(teacher_id=t_ids) |> arrange(teacher_id) |>
    mutate(teacher_idx=row_number())
  tarr  <- matrix(0L, nrow=sum(keep2), ncol=G)
  for (g in seq_len(G)) {
    tc <- teacher_cols[g]
    if (!is.na(tc) && tc %in% names(raw)) {
      ids  <- raw[[tc]][keep][keep2]
      idxs <- t_idx$teacher_idx[match(ids, t_idx$teacher_id)]
      idxs[is.na(idxs)] <- 0L
      tarr[,g] <- idxs
    }
  }
  list(data=list(N=sum(keep2), J=max(t_idx$teacher_idx), G=G,
                 Y=Y, obs=obs, n_obs=n_obs, teacher_id=tarr),
       index=t_idx)
}

