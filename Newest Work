```{r}
G <- 7
teacher_cols <- c("T1_ID", "T2_ID", NA, "T4_ID", "T5_ID",
                  ifelse(SUBJECT == "math", "J62T_ID", "J61T_ID"),
                  ifelse(SUBJECT == "math", "J72T_ID", "J71T_ID"))
score_cols <- paste0("score_C", c(1,2,3,4,5,6,7))

# Build wide data
wide <- raw |> select(CHILDID, all_of(score_cols))
all_scores <- unlist(wide[, score_cols])
sc_mean <- mean(all_scores, na.rm = TRUE)
sc_sd   <- sd(all_scores,   na.rm = TRUE)
wide <- wide |> mutate(across(all_of(score_cols), ~ (. - sc_mean) / sc_sd))

Y_mat     <- wide |> select(all_of(score_cols)) |> as.matrix()
obs_mask  <- (!is.na(Y_mat)) * 1L
Y_mat[is.na(Y_mat)] <- 0
n_obs_vec <- rowSums(obs_mask)
keep      <- n_obs_vec > 0
Y_mat     <- Y_mat[keep, ]
obs_mask  <- obs_mask[keep, ]
n_obs_vec <- n_obs_vec[keep]
N_tvaas   <- nrow(Y_mat)

# Build initial teacher index
all_teacher_ids <- c()
for (g in seq_len(G)) {
  tc <- teacher_cols[g]
  if (!is.na(tc) && tc %in% names(raw))
    all_teacher_ids <- c(all_teacher_ids, raw[[tc]][keep])
}
all_teacher_ids <- na.omit(unique(all_teacher_ids))

tvaas_teacher_index <- tibble(teacher_id = all_teacher_ids) |>
  arrange(teacher_id) |>
  mutate(teacher_idx = row_number())

# Build teacher array
teacher_array <- matrix(0L, nrow = N_tvaas, ncol = G)
for (g in seq_len(G)) {
  tc <- teacher_cols[g]
  if (!is.na(tc) && tc %in% names(raw)) {
    ids  <- raw[[tc]][keep]
    idxs <- tvaas_teacher_index$teacher_idx[match(ids, tvaas_teacher_index$teacher_id)]
    idxs[is.na(idxs)] <- 0L
    teacher_array[, g] <- idxs
  }
}

# ── Filter to >= 5 students and reindex contiguously ─────────────────────────
valid_tvaas_teachers <- tibble(teacher_idx = as.vector(teacher_array[teacher_array > 0])) |>
  count(teacher_idx) |>
  filter(n >= 5) |>
  left_join(tvaas_teacher_index, by = "teacher_idx") |>  # map idx → id
  pull(teacher_id)

# Rebuild index with fresh contiguous numbering
tvaas_teacher_index <- tvaas_teacher_index |>
  filter(teacher_id %in% valid_tvaas_teachers) |>
  mutate(teacher_idx_new = row_number())

# Remap array to new contiguous indices
teacher_array_clean <- matrix(0L, nrow = N_tvaas, ncol = G)
for (g in seq_len(G)) {
  old_idx <- teacher_array[, g]
  new_idx <- tvaas_teacher_index$teacher_idx_new[
    match(old_idx, tvaas_teacher_index$teacher_idx)
  ]
  new_idx[is.na(new_idx)] <- 0L
  teacher_array_clean[, g] <- new_idx
}

# Finalise index
tvaas_teacher_index <- tvaas_teacher_index |>
  select(teacher_id, teacher_idx = teacher_idx_new)

stan_data_tvaas <- list(
  N          = N_tvaas,
  J          = as.integer(max(tvaas_teacher_index$teacher_idx)),
  G          = G,
  Y          = Y_mat,
  obs        = obs_mask,
  n_obs      = n_obs_vec,
  teacher_id = teacher_array_clean
)

message(sprintf("  TVAAS — N=%d students, J=%d teachers, G=%d waves",
                stan_data_tvaas$N, stan_data_tvaas$J, stan_data_tvaas$G))
```






```{r}
# ── Fit ────────────────────────────────────────────────────────────────────────
mod_tvaas <- cmdstan_model("tvaas_model.stan")

fit_tvaas <- mod_tvaas$sample(
  data            = stan_data_tvaas,
  seed            = 141229,
  chains          = 4,
  parallel_chains = 4,
  iter_warmup     = 1500,   # ↑ from 1000 — more teachers = harder geometry
