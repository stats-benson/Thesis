# ── Helper functions (define once, use everywhere) ───────────────
get_theta <- function(fit, index_df, col_name) {
  fit$summary("theta", mean) |>
    mutate(teacher_idx = as.integer(str_extract(variable, "\\d+"))) |>
    left_join(index_df, by = "teacher_idx") |>
    select(teacher_id, !!col_name := mean)
}

make_theta_summary <- function(fit, index_df) {
  fit$summary("theta", mean, sd, ~quantile(.x, c(0.05, 0.95))) |>
    rename(mean = mean, sd = sd, q05 = `5%`, q95 = `95%`) |>
    mutate(
      teacher_idx = as.integer(str_extract(variable, "\\d+")),
      teacher_id  = index_df$teacher_id[teacher_idx]
    ) |>
    arrange(mean)
}
