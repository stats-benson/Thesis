```{r stan_data_prep}
# ══════════════════════════════════════════════════════════════════════════════
# CONSOLIDATED STAN DATA PREP
# Produces: stan_data (CVA) and stan_data_swvam (one-step SWVAM)
# Run this single chunk before fitting either model.
# ══════════════════════════════════════════════════════════════════════════════

# Drop any stale index columns from previous runs before rebuilding
long_clean <- long_clean |>
  select(-any_of(c("teacher_idx", "student_idx", "time_idx",
                   "teacher_idx.x", "teacher_idx.y",
                   "student_idx.x", "student_idx.y",
                   "time_idx.x",    "time_idx.y")))

# ── 1. Encode categorical covariates ──────────────────────────────────────────
long_clean <- long_clean |>
  mutate(
    female     = as.integer(GENDER   == 2),
    black      = as.integer(RACE     == 2),
    hispanic   = as.integer(RACE     == 3),
    asian      = as.integer(RACE     == 4),
    other_race = as.integer(RACE     == 5),
    disabled   = as.integer(P1DISABL == 1),
    poverty    = as.integer(WKPOV_R  == 1)
  )

# ── 2. Standardise continuous variables ───────────────────────────────────────
score_mean <- mean(long_clean$score,       na.rm = TRUE)
score_sd   <- sd(long_clean$score,         na.rm = TRUE)
prior_mean <- mean(long_clean$prior_score, na.rm = TRUE)
prior_sd   <- sd(long_clean$prior_score,   na.rm = TRUE)
ses_mean   <- mean(long_clean$WKSESL,      na.rm = TRUE)
ses_sd     <- sd(long_clean$WKSESL,        na.rm = TRUE)

long_clean <- long_clean |>
  mutate(
    y_std      = (score       - score_mean) / score_sd,
    y_prev_std = (prior_score - prior_mean) / prior_sd,
    ses_std    = (WKSESL      - ses_mean)   / ses_sd
  )

# ── 3. Step 1 OLS (for SWVAM residuals, also cleans NAs) ─────────────────────
step1_vars <- c("y_std", "y_prev_std", "wave", "female", "black", "hispanic",
                "asian", "other_race", "disabled", "ses_std", "poverty")

complete_rows <- complete.cases(long_clean[, step1_vars])
message(sprintf("  Complete cases: %d of %d rows (%.1f%% dropped)",
                sum(complete_rows), nrow(long_clean),
                100 * mean(!complete_rows)))

step1_formula <- y_std ~ y_prev_std + wave + female + black + hispanic +
                         asian + other_race + disabled + ses_std + poverty
step1_fit     <- lm(step1_formula, data = long_clean[complete_rows, ])

long_clean$gamma <- NA_real_
long_clean$gamma[complete_rows] <- residuals(step1_fit)

# Keep only rows with valid gamma (i.e. complete cases)
long_clean <- long_clean |> filter(!is.na(gamma))
message(sprintf("  Rows after step 1 filter: %d", nrow(long_clean)))

# ── 4. Build contiguous indices ───────────────────────────────────────────────
teacher_index <- long_clean |>
  distinct(teacher_id) |>
  arrange(teacher_id) |>
  mutate(teacher_idx = row_number())

student_index <- long_clean |>
  distinct(CHILDID) |>
  arrange(CHILDID) |>
  mutate(student_idx = row_number())

time_index <- long_clean |>
  distinct(wave) |>
  arrange(wave) |>
  mutate(time_idx = row_number())

long_clean <- long_clean |>
  left_join(teacher_index, by = "teacher_id") |>
  left_join(student_index, by = "CHILDID")    |>
  left_join(time_index,    by = "wave")

# ── 5. Build covariate matrix X ───────────────────────────────────────────────
X_mat <- long_clean |>
  select(female, black, hispanic, asian, other_race, disabled, poverty, ses_std) |>
  as.matrix()

# Mean-impute any remaining NAs in X
col_means <- colMeans(X_mat, na.rm = TRUE)
for (k in seq_len(ncol(X_mat))) {
  X_mat[is.na(X_mat[, k]), k] <- col_means[k]
}

# ── 6. Verify all required columns exist ──────────────────────────────────────
required <- c("student_idx", "teacher_idx", "time_idx", "y_std", "y_prev_std",
              "gamma", "wave")
missing  <- required[!required %in% names(long_clean)]
if (length(missing) > 0) stop("Missing columns: ", paste(missing, collapse = ", "))
message("  All required columns present")

# ── 7. CVA stan_data ──────────────────────────────────────────────────────────
stan_data <- list(
  N          = nrow(long_clean),
  J          = max(long_clean$teacher_idx),
  K          = ncol(X_mat),
  y          = long_clean$y_std,
  y_prev     = long_clean$y_prev_std,
  X          = X_mat,
  teacher_id = long_clean$teacher_idx
)

message(sprintf("  CVA   — N=%d, J=%d teachers, K=%d covariates",
                stan_data$N, stan_data$J, stan_data$K))

# ── 8. SWVAM stan_data ────────────────────────────────────────────────────────
stan_data_swvam <- list(
  N          = nrow(long_clean),
  I          = max(long_clean$student_idx),
  J          = max(long_clean$teacher_idx),
  K          = ncol(X_mat),
  TT         = max(long_clean$time_idx),
  y          = long_clean$y_std,
  X          = X_mat,
  student_id = long_clean$student_idx,
  teacher_id = long_clean$teacher_idx,
  time_id    = long_clean$time_idx
)

message(sprintf("  SWVAM — N=%d, I=%d students, J=%d teachers, TT=%d waves",
                stan_data_swvam$N, stan_data_swvam$I,
                stan_data_swvam$J, stan_data_swvam$TT))
```



```{r}
# ── Peer achievement P_it ──────────────────────────────────────────────────────
# Mean prior score of all students in the same school-wave cohort
peer_means <- long_clean |>
  group_by(school_id, wave) |>
  summarise(P = mean(y_prev_std, na.rm = TRUE), .groups = "drop")

long_clean <- long_clean |>
  left_join(peer_means, by = c("school_id", "wave"))

# ── School covariate matrix S (one row per teacher) ────────────────────────────
# Using school size, type, urbanicity, % minority as S_j
# These are time-varying in ECLS-K so we take the value at the teacher's wave
S_mat <- long_clean |>
  distinct(teacher_idx, .keep_all = TRUE) |>
  arrange(teacher_idx) |>
  select(S_enrls, S_sctyp, S_urban, S_minor) |>  # ← rename to your actual col names
  as.matrix()

# Mean-impute NAs
S_means <- colMeans(S_mat, na.rm = TRUE)
for (k in seq_len(ncol(S_mat))) {
  S_mat[is.na(S_mat[, k]), k] <- S_means[k]
}

# ── stan_data_composite ────────────────────────────────────────────────────────
stan_data_composite <- list(
  N          = nrow(long_clean),
  I          = max(long_clean$student_idx),
  J          = max(long_clean$teacher_idx),
  K          = ncol(X_mat),
  L          = ncol(S_mat),
  TT         = max(long_clean$time_idx),
  y          = long_clean$y_std,
  y_prev     = long_clean$y_prev_std,
  P          = long_clean$P,
  X          = X_mat,
  S          = S_mat,
  student_id = long_clean$student_idx,
  teacher_id = long_clean$teacher_idx,
  time_id    = long_clean$time_idx
)

message(sprintf("  Composite — N=%d, I=%d, J=%d, K=%d, L=%d, TT=%d",
                stan_data_composite$N, stan_data_composite$I,
                stan_data_composite$J, stan_data_composite$K,
                stan_data_composite$L, stan_data_composite$TT))
```
