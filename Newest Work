# ── Wave info including school characteristic columns ─────────────────────────
wave_info <- tibble(
  wave       = c("C1", "C2", "C4", "C5", "C6", "C7"),
  year       = c(1998L, 1999L, 2000L, 2002L, 2004L, 2007L),
  score_col  = c("score_C1", "score_C2", "score_C4", "score_C5", "score_C6", "score_C7"),
  prior_col  = c(NA,         "score_C1", "score_C3", "score_C4", "score_C5", "score_C6"),
  teach_col  = c("T1_ID",    "T2_ID",    "T4_ID",    "T5_ID",    "teacher_C6", "teacher_C7"),
  school_col = c("S1_ID",    "S2_ID",    "S4_ID",    "S5_ID",    "S6_ID",      "S7_ID"),
  # School characteristics — use closest available wave
  enrls_col  = c(NA,         NA,         "S4ENRLS",  "S5ENRLS",  "S6ENRLS",    "S7ENRLS"),
  minor_col  = c(NA,         NA,         "S4MINOR",  "S5MINOR",  "S6MINOR",    "S7MINOR"),
  sctyp_col  = c(NA,         NA,         "S4SCTYP",  "S5SCTYP",  "S6SCTYP",    "S7SCTYP"),
  urban_col  = c(NA,         "R3URBAN",  "R4URBAN",  "R5URBAN",  "R6URBAN",    "R7URBAN"),
  region_col = c(NA,         "R3REGION", "R4REGION", "R5REGION", "R6REGION",   "R7REGION")
)

long_list <- vector("list", nrow(wave_info))

for (i in seq_len(nrow(wave_info))) {
  w <- wave_info[i, ]

  tmp <- raw |>
    select(
      CHILDID,
      GENDER, RACE, P1DISABL, WKSESL, WKPOV_R,
      score      = all_of(w$score_col),
      teacher_id = all_of(w$teach_col),
      school_id  = all_of(w$school_col)
    ) |>
    mutate(
      wave        = w$wave,
      year        = w$year,
      prior_score = if (is.na(w$prior_col)) NA_real_ else raw[[w$prior_col]],
      S_enrls     = if (is.na(w$enrls_col))  NA_real_ else raw[[w$enrls_col]],
      S_minor     = if (is.na(w$minor_col))  NA_real_ else raw[[w$minor_col]],
      S_sctyp     = if (is.na(w$sctyp_col))  NA_real_ else raw[[w$sctyp_col]],
      S_urban     = if (is.na(w$urban_col))  NA_real_ else raw[[w$urban_col]],
      S_region    = if (is.na(w$region_col)) NA_real_ else raw[[w$region_col]]
    )

  long_list[[i]] <- tmp
}

long <- bind_rows(long_list)
message(sprintf("  Long data: %d rows before filtering", nrow(long)))
