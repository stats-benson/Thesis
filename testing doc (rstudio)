```



```{r}

student_sensitivity <- summary(fit, pars = "a")$summary[, "mean"]


edu_subset$stan_resid <- edu_subset$post_test - (summary(fit, pars="alpha")$summary[edu_subset$student_idx, "mean"] * 
                                                 teacher_results$estimate[edu_subset$teacher_idx])

# 3. Plot residuals by Sensitivity
ggplot(edu_subset, aes(x = student_sensitivity[student_idx], y = stan_resid)) +
  geom_bin2d(bins = 50) + 
  scale_fill_viridis_c() +
  geom_smooth(method = "lm", color = "red") +
  theme_minimal() +
  labs(title = "Student-Level Diagnostic",
       x = "Student Sensitivity (a_i)", y = "Model Residuals")

```



