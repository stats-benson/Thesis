```{r}
# Extract Teacher Estimates
teacher_summary <- as.data.frame(summary(fit, pars = "theta")$summary) %>%
  mutate(T4_ID = levels(as.factor(edu_subset$T4_ID))) %>%
  rename(estimate = mean, se = sd) %>%
  arrange(estimate) %>%
  mutate(rank = -row_number())

top_teachers <- tail(teacher_summary, n=10)


# Teacher-Level Plot
p_teacher <- ggplot(top_teachers, aes(x = rank, y = estimate)) +
  geom_pointrange(aes(ymin = `2.5%`, ymax = `97.5%`, size = 0.5/se^2), 
                  alpha = 0.6, color = "midnightblue") +
  scale_size_continuous(name = "Precision (1/var)") +
  theme_minimal() +
  labs(title = "Teacher Value-Added Rankings (SW-VAM)",
       subtitle = "Larger points indicate higher signal reliability",
       x = "Teacher Rank", y = "Estimated Effect (theta)")

print(p_teacher)
```
```{r}
# Extract Student Parameters (assuming alpha and a are in your Stan model)
student_params <- data.frame(
  CHILDID = levels(as.factor(edu_subset$CHILDID)),
  alpha = summary(fit, pars = "alpha")$summary[, "mean"],
  sensitivity = summary(fit, pars = "a")$summary[, "mean"]
)

# Student-Level Diagnostic Plot
p_student <- ggplot(student_params, aes(x = sensitivity, y = alpha)) +
  geom_hex(bins = 30) + 
  scale_fill_viridis_c(option = "magma") +
  geom_smooth(method = "lm", color = "cyan", linetype = "dashed") +
  theme_minimal() +
  labs(title = "Student-Level Signal Quality",
       subtitle = "Relationship between Reliability (alpha) and Sensitivity (a)",
       x = "Sensitivity (a_i)", y = "Reliability (alpha_i)")

print(p_student)

```
